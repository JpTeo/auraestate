# Aura Estates — static site cache & delivery rules
# Copy to project root on any Apache host (Hostinger, etc.)

# ---- Compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript image/svg+xml
</IfModule>

# ---- Cache strategy ----
# HTML: never cache aggressively — always revalidate, so content edits show immediately.
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType image/jpeg "access plus 7 days"
  ExpiresByType image/png "access plus 7 days"
  ExpiresByType image/webp "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 7 days"
</IfModule>

# ---- Charset ----
AddDefaultCharset UTF-8

# ---- Pretty error fallback (optional) ----
ErrorDocument 404 /index.html
